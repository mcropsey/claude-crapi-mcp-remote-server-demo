# crapi-mcp environment — edit values, keep this file out of version control.
# Loaded by the systemd unit via EnvironmentFile.
#
# Typical layout: this MCP server runs on its own box (e.g. 192.168.1.102) and
# reaches crAPI over the network on another box (e.g. 192.168.1.101:8888).
# Single-box is fine too — just point CRAPI_BASE at wherever crAPI listens.

# Where crAPI is reachable FROM this box:
CRAPI_BASE=http://192.168.1.101:8888

# Listen address/port for this MCP server.
# 8009 is used (not 8000) to stay clear of common defaults like chromadb/8000.
MCP_HOST=0.0.0.0
MCP_PORT=8009
MCP_PATH=/mcp

# Optional: require clients to send  Authorization: Bearer <value>  to the MCP
# endpoint. Strongly recommended so only you can drive the attack tools.
# Generate one with:  openssl rand -hex 24
# MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# Optional: pre-seed a crAPI session token. Usually leave this blank and just
# call the `login` tool from Claude — it stores the token in memory at runtime.
# CRAPI_TOKEN=
